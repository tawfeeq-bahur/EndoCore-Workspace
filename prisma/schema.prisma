// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                         String         @id @default(uuid())
  name                       String
  email                      String         @unique
  passwordHash               String
  avatarUrl                  String         @default("https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=150&auto=format&fit=crop&q=80")
  activeGroup                String         @default("Engineering Group")
  privacyMode                String         @default("Public")
  deviceConnected            String         @default("WS-WORKSTATION-11")
  productivityGoal           Int            @default(6)
  customStatus               String         @default("")
  theme                      String         @default("endocore-dark")
  friendUpdatesNotification  Boolean        @default(true)
  breakRemindersNotification Boolean        @default(true)
  aiNudgesNotification       Boolean        @default(true)
  createdAt                  DateTime       @default(now())
  status                     String         @default("online") // online, busy, away, focus, offline
  role                       String         @default("Software Developer")
  broadcastGroups            String         @default("Engineering Group")
  lastHeartbeat              DateTime       @default(now())
  distractionsCount          Int            @default(0)
  focusStreak                Int            @default(0)
  lastFocusDate              String         @default("")

  // New Fields for Connections
  username                   String         @unique @default(uuid())
  headline                   String         @default("Software Developer")

  // Privacy preferences
  presenceVisibility         String         @default("connections")    // everyone, connections, room_members, nobody
  activityVisibility         String         @default("status_only")    // status_only, app_category, app_name
  showDailyFocusTime         Boolean        @default(false)
  showCurrentRoom            Boolean        @default(false)
  allowFocusInvites          Boolean        @default(true)
  allowRoomInvites           Boolean        @default(true)
  allowJoinRequests          Boolean        @default(true)

  // Relations
  activities                 Activity[]
  memberships                GroupMember[]
  activityLogs               ActivityLog[]
  dailySummaries             DailySummary[]
  focusSessions              FocusSession[]

  // Room intelligence relations
  roomMemberships            RoomMember[]
  roomInvitationsSent        RoomInvitation[] @relation("InvitedByRelation")

  // Connections relations
  sentConnections            Connection[]   @relation("ConnectionRequester")
  connectionsA               Connection[]   @relation("ConnectionUserA")
  connectionsB               Connection[]   @relation("ConnectionUserB")
  blocksSent                 UserBlock[]    @relation("UserBlocker")
  blocksReceived             UserBlock[]    @relation("UserBlocked")

  // Group join requests & invitations
  joinRequests               GroupJoinRequest[]
  sentGroupInvites           GroupInvitation[] @relation("GroupInviter")
  receivedGroupInvites       GroupInvitation[] @relation("GroupInvitee")

  // Focus challenges
  challengesCreated          FocusChallenge[] @relation("ChallengeCreator")
  challengesInvited          FocusChallenge[] @relation("ChallengeInvited")
}

model Group {
  id          String        @id @default(uuid())
  name        String        @unique
  description String
  createdAt   DateTime      @default(now())
  accessType  String        @default("PUBLIC") // PUBLIC, PRIVATE, REQUIRE_APPROVAL, INVITE_ONLY
  members     GroupMember[]
  joinRequests GroupJoinRequest[]
  invitations  GroupInvitation[]
}

model GroupMember {
  userId  String
  groupId String
  role    String @default("member") // admin, member
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Activity {
  id              String   @id @default(uuid())
  userId          String
  app             String
  project         String
  startedAt       DateTime @default(now())
  durationSeconds Int      @default(0)
  isPaused        Boolean  @default(false)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id           String   @id @default(uuid())
  userId       String
  app          String
  project      String
  timestamp    DateTime @default(now())
  durationText String   @default("Running...")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  userName  String
  avatarUrl String   @default("")
  message   String
  timestamp DateTime @default(now())
}

model DailySummary {
  id                String   @id @default(uuid())
  userId            String
  date              String   // YYYY-MM-DD
  totalFocusSeconds Int      @default(0)
  productivityScore Int      @default(0)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model FocusSession {
  id              String   @id @default(uuid())
  userId          String
  taskName        String
  durationMinutes Int
  completed       Boolean  @default(false)
  timestamp       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}

model Connection {
  id            String           @id @default(uuid())
  pairKey       String           @unique // canonical form: userAId:userBId where userAId < userBId

  userAId       String
  userBId       String
  requestedById String

  status        ConnectionStatus @default(PENDING)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  respondedAt   DateTime?
  acceptedAt    DateTime?

  userA         User @relation("ConnectionUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB         User @relation("ConnectionUserB", fields: [userBId], references: [id], onDelete: Cascade)
  requester     User @relation("ConnectionRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([userAId, status])
  @@index([userBId, status])
  @@index([requestedById])
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker   User     @relation("UserBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("UserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

enum FocusChallengeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
  EXPIRED
  ACTIVE
  COMPLETED
}

model FocusChallenge {
  id               String               @id @default(uuid())
  createdById      String
  invitedUserId    String

  durationMinutes  Int
  challengeMode    String               @default("co_focus") // "co_focus", "sprint", "accountability"
  creatorObjective String               @default("")
  invitedObjective String               @default("")
  creatorStatus    String               @default("pending") // "pending", "completed", "partial", "failed"
  invitedStatus    String               @default("pending")

  status           FocusChallengeStatus @default(PENDING)

  createdAt        DateTime             @default(now())
  expiresAt        DateTime
  respondedAt      DateTime?
  startAt          DateTime?
  endAt            DateTime?
  completedAt      DateTime?

  creator          User                 @relation("ChallengeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  invited          User                 @relation("ChallengeInvited", fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@index([createdById, status])
  @@index([invitedUserId, status])
}

model GroupJoinRequest {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model GroupInvitation {
  id         String   @id @default(uuid())
  groupId    String
  inviterId  String
  inviteeId  String
  status     String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  createdAt  DateTime @default(now())

  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter    User     @relation("GroupInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee    User     @relation("GroupInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([groupId, inviteeId])
}

// -------------------------------------------------------------
// EndoCore Room System 2.0 Enums & Models
// -------------------------------------------------------------

enum AccessMode {
  OPEN
  APPROVAL_REQUIRED
  INVITE_ONLY
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  OBSERVER
}

enum MembershipStatus {
  ACTIVE
  PENDING_APPROVAL
  INVITED
  REMOVED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum ScheduleExceptionType {
  LEAVE
  HOLIDAY
  SICK_DAY
  MEETING
  MANUAL_BREAK
  OFFLINE_TIME
  TIMEZONE_EXCEPTION
}

enum AlertType {
  FOCUS_DEFICIT
  DELIVERY_RISK
  EXCESSIVE_CONTEXT_SWITCH
  BURNOUT_WARNING
}

enum AlertLevel {
  LEVEL_1_PRIVATE_NUDGE
  LEVEL_2_OWNER_ADVISORY
  LEVEL_3_CRITICAL_ROOM_ALERT
}

enum TaskSource {
  NATIVE
  GITHUB
  JIRA
  LINEAR
}

model Room {
  id                     String        @id @default(uuid())
  ownerId                String
  name                   String        @unique
  description            String
  iconEmoji              String        @default("🚀")
  category               String        @default("Development") // Development, Design, Research, Study, Custom
  timezone               String        @default("UTC")
  accessMode             AccessMode    @default(APPROVAL_REQUIRED)
  deadline               DateTime?
  status                 String        @default("active")

  // Versioned Settings & Policies
  aiPolicy               Json
  aiPolicyVersion        Int           @default(1)
  privacyPolicy          Json
  privacyPolicyVersion   Int           @default(1)

  allowAdminInvites      Boolean       @default(true)
  linkExpiryDays         Int           @default(7)
  maxMemberCount         Int           @default(50)
  requireVerifiedAccount  Boolean       @default(false)
  defaultMemberRole      MemberRole    @default(MEMBER)
  idempotencyKey         String?       @unique

  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  // Relations
  members                RoomMember[]
  invitations            RoomInvitation[]
  memberTargets          MemberWorkTarget[]
  teamTargets            TeamTarget[]
  scheduleExceptions     MemberScheduleException[]
  tasks                  Task[]
  activitySessions       ActivitySession[]
  dailyRollups           DailyMemberRollup[]
  aiInsights             AiInsight[]
  alertEscalations       AlertEscalation[]
  consentRecords         TrackingConsent[]

  @@index([ownerId])
  @@index([status])
}

model RoomMember {
  roomId               String
  userId               String
  role                 MemberRole       @default(MEMBER)
  membershipStatus     MembershipStatus @default(ACTIVE)
  joinedAt             DateTime         @default(now())

  room                 Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([roomId, membershipStatus])
  @@index([userId])
}

model RoomInvitation {
  id                   String           @id @default(uuid())
  roomId               String
  invitedById          String
  invitedUserId        String?
  email                String?
  tokenHash            String           @unique
  status               InvitationStatus @default(PENDING)
  expiresAt            DateTime
  acceptedByUserId     String?
  usedAt               DateTime?
  revokedAt            DateTime?
  createdAt            DateTime         @default(now())

  room                 Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  invitedBy            User             @relation("InvitedByRelation", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([roomId, status])
  @@index([email])
  @@index([invitedUserId])
}

model MemberWorkTarget {
  id                   String           @id @default(uuid())
  roomId               String
  userId               String
  focusMinutes         Int              @default(360)
  taskTarget           Int              @default(5)
  workingDays          String           @default("Mon,Tue,Wed,Thu,Fri")
  workStart            String           @default("09:00")
  workEnd              String           @default("17:00")
  breakAllowanceMins   Int              @default(60)
  deepWorkTargetMins   Int              @default(180)
  minCheckinFreq       String           @default("Daily")
  effectiveFrom        DateTime         @default(now())
  effectiveUntil       DateTime?
  createdById          String
  createdAt            DateTime         @default(now())
  changeReason         String?

  room                 Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, userId, effectiveFrom])
}

model TeamTarget {
  id                    String           @id @default(uuid())
  roomId                String
  focusMinutes          Int              @default(2400)
  taskPoints            Int              @default(50)
  deadline              DateTime?
  reportingPeriod       String           @default("Weekly")
  requiredCoverageHours String           @default("09:00-17:00 UTC")
  milestonesJson        Json             @default("[]")
  effectiveFrom         DateTime         @default(now())
  effectiveUntil        DateTime?
  createdById           String
  createdAt             DateTime         @default(now())
  changeReason          String?

  room                  Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, effectiveFrom])
}

model MemberScheduleException {
  id                   String           @id @default(uuid())
  roomId               String
  userId               String
  type                 ScheduleExceptionType
  startsAt             DateTime
  endsAt               DateTime
  reason               String?
  approvedById         String?
  createdAt            DateTime         @default(now())

  room                 Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, userId, startsAt, endsAt])
}

model ActivitySession {
  id                   String           @id @default(uuid())
  roomId               String
  userId               String
  appCategory          String
  appName              String
  startedAt            DateTime
  endedAt              DateTime
  activeSeconds        Int
  idleSeconds          Int              @default(0)
  contextSwitches      Int              @default(0)
  isDeepWork           Boolean          @default(false)
  source               String           @default("DESKTOP_AGENT")

  room                 Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, startedAt])
  @@index([userId, startedAt])
}

model Task {
  id                   String           @id @default(uuid())
  roomId               String
  assigneeId           String?
  title                String
  description          String?
  points               Int              @default(1)
  status               String           @default("TODO") // TODO, IN_PROGRESS, COMPLETED
  source               TaskSource       @default(NATIVE)
  externalId           String?
  externalUrl          String?
  lastSyncedAt         DateTime?
  dueAt                DateTime?
  completedAt          DateTime?
  createdAt            DateTime         @default(now())

  room                 Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, status])
  @@index([assigneeId])
}

model DailyMemberRollup {
  id                   String           @id @default(uuid())
  roomId               String
  userId               String
  date                 String           // YYYY-MM-DD
  focusMinutes         Int              @default(0)
  activeMinutes        Int              @default(0)
  idleMinutes          Int              @default(0)
  tasksCompleted       Int              @default(0)
  storyPointsCompleted Int              @default(0)
  contextSwitches      Int              @default(0)

  // Calculated Metrics (Capped for scoring, original stored)
  effortProgress       Float            @default(0)
  deliveryProgress     Float            @default(0)
  contributionShare    Float            @default(0)
  consistencyScore     Float            @default(0)
  focusQualityScore    Float            @default(0)
  contributionScore    Float            @default(0)

  // Audit Metadata for Explainability
  formulaVersion       Int              @default(1)
  weightDistribution   Json
  dataLimitations      Json
  confidenceScore      Float            @default(1.0)
  createdAt            DateTime         @default(now())

  room                 Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId, date])
  @@index([roomId, date])
  @@index([userId, date])
}

model AlertEscalation {
  id                  String           @id @default(uuid())
  roomId              String
  userId              String?
  alertType           AlertType
  currentLevel        AlertLevel       @default(LEVEL_1_PRIVATE_NUDGE)
  firstDetectedAt     DateTime         @default(now())
  privateNudgeSentAt  DateTime?
  ownerAdvisorySentAt DateTime?
  criticalAlertSentAt DateTime?
  nextEvaluationAt    DateTime?
  resolvedAt          DateTime?
  evidenceJson        Json

  room                Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, userId, alertType, resolvedAt])
}

model TrackingConsent {
  id                  String           @id @default(uuid())
  roomId              String
  userId              String
  policyVersion       Int
  acceptedAt          DateTime         @default(now())
  revokedAt           DateTime?

  room                Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, userId, policyVersion])
}

model AiInsight {
  id                   String           @id @default(uuid())
  roomId               String
  insightType          String
  severity             String           @default("INFO") // INFO, WARNING, CRITICAL
  confidence           Float            @default(1.0)
  evidenceJson         Json
  generatedAt          DateTime         @default(now())
  expiresAt            DateTime?

  room                 Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, generatedAt])
}

